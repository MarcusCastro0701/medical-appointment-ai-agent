OPENROUTER_API_KEY=your_openrouter_api_key_here

LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=03-medical-appointment

# Auth / database
DATABASE_URL=postgresql://user:password@localhost:5432/medical_appointment
JWT_SECRET=your_jwt_secret_here
ENCRYPT_PEPPER=your_password_pepper_here

# Chat
MAX_CHAT_MESSAGES=20

# CORS - comma-separated list of allowed origins (e.g. http://localhost:5173).
# If unset, all origins are reflected (fine since auth uses Bearer tokens, not cookies).
CORS_ORIGIN=
