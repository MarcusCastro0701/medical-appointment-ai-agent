{
  "name": "medical-appointment-agent",
  "version": "1.0.0",
  "description": "AI agent for scheduling and cancelling medical appointments, built with LangGraph, LangChain, OpenRouter and Fastify",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --env-file .env src/index.ts",
    "dev": "node --watch --inspect --env-file .env src/index.ts",
    "test": "node --env-file .env --test tests/**/*.test.ts",
    "test:dev": "node --inspect --env-file .env --test --watch tests/**/*.test.ts",
    "test:unit:dev": "node --inspect --test --watch tests/**/*unit.test.ts",
    "test:unit": "node --inspect --test tests/**/*unit.test.ts",
    "test:e2e:dev": "node --inspect --env-file .env --test --watch tests/**/*e2e.test.ts",
    "test:e2e": "node --inspect --env-file .env --test tests/**/*e2e.test.ts",
    "langgraph:serve": "npx @langchain/langgraph-cli dev",
    "migration:generate": "prisma migrate dev",
    "migration:run": "prisma migrate deploy",
    "seed": "prisma db seed"
  },
  "prisma": {
    "seed": "node --env-file .env prisma/seed.ts"
  },
  "keywords": [
    "langchain",
    "langgraph",
    "openrouter",
    "fastify",
    "ai-agent",
    "medical-appointment"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^11.1.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.7",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.4",
    "@langchain/openai": "^1.2.5",
    "@openrouter/sdk": "^0.5.1",
    "@prisma/client": "^6.16.3",
    "bcrypt": "^6.0.0",
    "fastify": "^5.7.4",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.2.17"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.12",
    "prisma": "^6.16.3"
  },
  "engines": {
    "node": ">=22.6.0"
  }
}
